# Dependency directories
node_modules/
.pnp/
.pnp.*
.yarn/

# Build and output directories
.next/
out/
build/
dist/
.vercel/
.turbo/

# Large lock files (unless specifically debugging dependencies)
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# Local environment and secret files
.env
.env.*
*.pem
*.key

# Git metadata
.git/

# Cache and temporary files
.cache/
*.tsbuildinfo
next-env.d.ts
.DS_Store
Thumbs.db

# Logs and debug files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
ts_errors.txt
build.log

# Media assets (to avoid token waste on binary descriptions)
public/images/
public/videos/
public/assets/
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.mp4
*.webm
